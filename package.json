{
  "name": "otp-mail-to-teams-service",
  "version": "1.0.0",
  "description": "Servicio NestJS para leer OTP desde correo y publicarlo en Microsoft Teams",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "lint": "eslint . --ext .ts --ignore-pattern eslint.config.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:key:generate": "node -e \"console.log(require('node:crypto').randomBytes(32).toString('base64'))\""
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "nestjs",
    "otp",
    "imap",
    "teams-webhook"
  ],
  "author": "Miguel Zapata",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^6.16.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.15.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "prisma": "^6.16.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
