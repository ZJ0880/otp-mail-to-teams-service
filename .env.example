APP_PORT=3000
APP_ENABLE_POLLING=false
APP_ADMIN_USER=admin
APP_ADMIN_PASSWORD=change-me
APP_JWT_SECRET=replace-with-long-random-secret
AUTH_JWT_ISSUER=otp-mail-to-teams-service
AUTH_JWT_AUDIENCE=otp-mail-to-teams-clients
AUTH_TOKEN_TTL_MINUTES=60
APP_CORS_ORIGINS=http://localhost:4200
DATABASE_URL=postgresql://otp_user:otp_password@localhost:5432/otp_ticket_db?schema=public
REDIS_URL=redis://localhost:6379
SECRETS_ENCRYPTION_KEY=replace-with-base64-32-byte-key
APP_ADMIN_PANEL_BASE_URL=http://localhost:3000
APP_APPROVAL_LINK_SECRET=replace-with-another-long-random-secret
APP_APPROVAL_LINK_TTL_MINUTES=15

MAIL_HOST=imap.gmail.com
MAIL_PORT=993
MAIL_SECURE=true
MAIL_USER=your-bot-account@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_MAILBOX=INBOX
MAIL_ALLOWED_FROM=
MAIL_SUBJECT_KEYWORDS=otp,codigo,codigo de verificacion
OTP_REGEX_PATTERNS=\b(\d{6})\b
OTP_TTL_MINUTES=5
APP_POLLING_INTERVAL_SECONDS=20
TEAMS_WEBHOOK_URL=https://your-webhook-url
TEAMS_MESSAGE_TEMPLATE=ALERTA OTP\\n\\nCodigo: **{otp}**\\nFecha: {receivedAt}\\nRemitente: {from}\\nAsunto: {subject}\\n\\nAccion: usa este codigo de inmediato y no lo compartas.
