MAIL_HOST=imap.gmail.com
MAIL_PORT=993
MAIL_SECURE=true
MAIL_USER=your-bot-account@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_MAILBOX=INBOX
MAIL_ALLOWED_FROM=
MAIL_SUBJECT_KEYWORDS=otp,codigo,codigo de verificacion
OTP_REGEX_PATTERNS=\b(\d{6})\b
OTP_TTL_MINUTES=5
APP_POLLING_INTERVAL_SECONDS=20
TEAMS_WEBHOOK_URL=https://your-webhook-url
TEAMS_MESSAGE_TEMPLATE=ALERTA OTP\\n\\nCodigo: **{otp}**\\nFecha: {receivedAt}\\nRemitente: {from}\\nAsunto: {subject}\\n\\nAccion: usa este codigo de inmediato y no lo compartas.
